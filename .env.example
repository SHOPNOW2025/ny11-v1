# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=your_gemini_api_key_here

# APP_URL: The URL where this applet is hosted.
APP_URL=http://localhost:3000

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Groq Configuration
VITE_GROQ_API_KEY=your_groq_api_key_here

# Mastercard Configuration
MASTERCARD_GATEWAY_URL=https://test-gateway.mastercard.com
MASTERCARD_MERCHANT_ID=your_merchant_id
MASTERCARD_API_PASSWORD=your_api_password
VITE_MASTERCARD_MERCHANT_ID=your_merchant_id

PORT=3000
CALLBACK_BASE_URL=http://localhost:3000
